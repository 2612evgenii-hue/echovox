# Копируйте в `.env` в корне проекта (файл `.env` уже в .gitignore).
# EmailJS — письмо-уведомление при отправке формы на сайте (запись в БД идёт через PHP / mock и не зависит от этого).
# https://www.emailjs.com → Email Services, Email Templates, Account → API keys
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
